APP_DEBUG = true
# 是否开启定时任务
CRON_ENABLE = false


DB_TYPE = mysql
DB_HOST = 127.0.0.1
DB_NAME = test
DB_USER = username
DB_PASS = password
DB_PORT = 3306
DB_CHARSET = utf8

DEFAULT_LANG = zh-cn

# 缓存（默认 redis；本地无 redis 可改为 file）
CACHE_DRIVER = redis
CACHE_PREFIX =
CACHE_EXPIRE = 0
CACHE_TAG_PREFIX = tag:

# Redis
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD =
REDIS_TIMEOUT = 0
REDIS_PERSISTENT = false
REDIS_CACHE_DB = 0

# Swoole HTTP/Worker
SWOOLE_HTTP_HOST = 0.0.0.0
SWOOLE_HTTP_PORT = 8080
SWOOLE_WORKER_NUM = 0
SWOOLE_MAX_REQUEST = 2000
SWOOLE_RELOAD_ASYNC = true
SWOOLE_MAX_WAIT_TIME = 60
SWOOLE_HEARTBEAT_IDLE_TIME = 120
SWOOLE_HEARTBEAT_CHECK_INTERVAL = 60
SWOOLE_POOL_MAX_WAIT_TIME = 5
SWOOLE_DB_POOL_MAX_ACTIVE = 3
SWOOLE_CACHE_POOL_MAX_ACTIVE = 3
SWOOLE_REDIS_POOL_MAX_ACTIVE = 3

# CORS（逗号分隔白名单；可用 * 放开）
CORS_ALLOWED_ORIGINS = http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_METHODS = GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS = Authorization,Content-Type,X-Requested-With

# Log（按天分片，保留文件数）
LOG_SINGLE = false
LOG_MAX_FILES = 30
