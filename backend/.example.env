# ============================================================
# backend/.example.env —— ThinkPHP 业务配置模板（运行时）
# ============================================================
# 用途：ThinkPHP 运行时通过 env 函数读取的完整业务配置，约 30 字段。
#      本文件是 backend/.env 的模板，首次启动通过以下任一方式生成 backend/.env：
#        1. 手动：cp backend/.example.env backend/.env 后按注释修改
#        2. 零配置：docker compose up 时 ensure-env 服务自动生成 + 随机化敏感字段
#
# Docker compose 变量插值的模板在 deploy/docker/.example.env（和本文件分工不同）。
# 下方标注 ⚠️ 的字段需与根目录 .env 的同名字段保持一致；详见 docs/env-files.md。
# ============================================================

# -------- 应用 --------
# 调试模式（生产必须设为 false）
APP_DEBUG=true
# 是否开启定时任务
CRON_ENABLE=false
# 默认语言
DEFAULT_LANG=zh-cn

# -------- 数据库 --------
DB_TYPE=mysql
# 连接目标：用 compose mysql 容器填 mysql；连宿主 MySQL 填 host.docker.internal；本地 swoole 直跑填 127.0.0.1
DB_HOST=mysql
# ⚠️ 此字段需与根目录 .env 的 DB_NAME 一致
DB_NAME=mallbase
# ⚠️ 此字段需与根目录 .env 的 DB_USER 一致；不要使用 root
DB_USER=mallbase
# ⚠️ 此字段需与根目录 .env 的 DB_PASS 一致；首次 ensure-env 会替换为随机值
DB_PASS=please-change-or-leave-for-random
# ThinkPHP 连 MySQL 的容器内端口，固定 3306；不是宿主暴露端口（那个是 MYSQL_PORT）
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_PREFIX=mb_

# -------- 缓存（默认 redis；本地无 redis 可改为 file） --------
CACHE_DRIVER=redis
CACHE_PREFIX=
CACHE_EXPIRE=0
CACHE_TAG_PREFIX=tag:

# -------- Redis --------
# Redis 主机：用 compose redis 容器填 redis；连宿主 Redis 填 host.docker.internal；本地直跑填 127.0.0.1
REDIS_HOST=redis
# ThinkPHP 连 Redis 的端口（cache.php / swoole.php 都读它）
# - compose 部署：必须保持 6379（redis 容器内监听 6379）；想改宿主暴露端口去根 .env 改 REDIS_PORT
# - 本地直跑：改成宿主 Redis 的实际端口
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=0
REDIS_PERSISTENT=false
REDIS_CACHE_DB=0

# -------- JWT（首次 ensure-env 会生成随机值；安装向导也会写入） --------
JWT_SECRET=please-change-or-leave-for-random
JWT_EXPIRE=7200
JWT_REFRESH_EXPIRE=2592000

# -------- Swoole HTTP/Worker --------
SWOOLE_HTTP_HOST=0.0.0.0
# ⚠️ 此字段需与根目录 .env 的 SWOOLE_HTTP_PORT 一致
SWOOLE_HTTP_PORT=8080
SWOOLE_WORKER_NUM=0
SWOOLE_MAX_REQUEST=2000
SWOOLE_RELOAD_ASYNC=true
SWOOLE_MAX_WAIT_TIME=60
SWOOLE_HEARTBEAT_IDLE_TIME=120
SWOOLE_HEARTBEAT_CHECK_INTERVAL=60
SWOOLE_POOL_MAX_WAIT_TIME=5
SWOOLE_DB_POOL_MAX_ACTIVE=3
SWOOLE_CACHE_POOL_MAX_ACTIVE=3
SWOOLE_REDIS_POOL_MAX_ACTIVE=3

# -------- CORS（逗号分隔白名单；可用 * 放开） --------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5666,http://127.0.0.1:5666,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With

# -------- 日志（按天分片，保留文件数） --------
LOG_SINGLE=false
LOG_MAX_FILES=30
