# Docker dev data（MySQL / Redis 宿主挂载目录，仅项目根的 /data/）
/data/


# Environment files（两份独立 .env，内含敏感信息，均不入库）
.env
backend/.env

# Docker dev generated install state
deploy/install/install.lock

# 部署脚本的本地配置（含真实主机 / 私钥 / 远程目录，不入库）
deploy/upload-frontend.local.sh

# 工作过程产生的临时目录（截图中转、调试输出等）
.tmp/
