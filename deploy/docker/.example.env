# ============================================================
# deploy/docker/.example.env —— Docker compose 变量模板
# ============================================================
# 用途：docker-compose.dev.yml / docker-compose.yml 做变量插值用。
#      只含 compose 需要的字段；ThinkPHP 运行时配置请看 backend/.example.env。
#
# 使用方式（三选一）：
#   1. 零配置：docker compose up 时 ensure-env 容器自动生成根 .env 并随机化敏感字段。
#   2. 自定义：cp deploy/docker/.example.env .env，按注释修改后再 docker compose up -d。
#   3. 不改：直接 docker compose up -d，走零配置路径。
#
# ⚠️ 本文件字段必须与 backend/.example.env 中同名字段保持语义一致；
#    ensure-env 脚本会根据本文件派生 / 补齐根 .env。
# ============================================================

# -------- 后端暴露端口 --------
# backend 容器对外暴露的 HTTP 端口；浏览器访问 http://localhost:该端口
# 同时也是 Swoole 在容器内监听的端口，保持一致
SWOOLE_HTTP_PORT=8080

# -------- MySQL --------
# 宿主机暴露的 MySQL 端口（用 Navicat / DBeaver 连本容器时用）。
# 容器内 MySQL 固定监听 3306，这里只改宿主映射。
MYSQL_PORT=3306
# 数据库 root 账号密码。⚠️ 仅首次容器初始化时生效；改密码需先 docker compose down -v 清 data。
# ensure-env 自动生成时会替换为随机 24 位字符串。
MYSQL_ROOT_PASSWORD=please-change-or-leave-for-random

# -------- Redis --------
# 宿主机暴露的 Redis 端口。容器内 Redis 固定监听 6379。
REDIS_PORT=6379

# -------- 业务数据库（compose 会用这 3 个字段初始化 MySQL 容器，同时 ThinkPHP 也读取） --------
# 数据库名
DB_NAME=mallbase
# 业务数据库用户（非 root）
DB_USER=mallbase
# 业务数据库密码。ensure-env 自动生成时会替换为随机 24 位字符串。
DB_PASS=please-change-or-leave-for-random
